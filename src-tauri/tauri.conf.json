{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synapses",
  "version": "0.8.0",
  "identifier": "com.synapsesos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm ci --silent && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Synapses",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://127.0.0.1:11435 https://synapsesos.com; font-src 'self' data:; frame-ancestors 'none'; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": {
      "resources/synapses-aarch64-apple-darwin": "synapses-aarch64-apple-darwin",
      "resources/synapses-x86_64-apple-darwin": "synapses-x86_64-apple-darwin",
      "resources/synapses-x86_64-unknown-linux-gnu": "synapses-x86_64-unknown-linux-gnu"
    }
  },
  "plugins": {
    "shell": {
      "open": "^https://"
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxQzYxRTE4MDFEOEM1NDMKUldSRHhkZ0JHQjdHY1NWOWhMR2lJUXlZKzhSTDVEZ3ZGNnM2NEVOcm1yekJKSjNlT1VWVnZZRVQK",
      "endpoints": [
        "https://github.com/SynapsesOS/synapses-app/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
