{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synapses",
  "version": "0.1.0",
  "identifier": "com.synapsesos.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Synapses",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": {
      "resources/synapses-aarch64-apple-darwin": "synapses-aarch64-apple-darwin",
      "resources/synapses-x86_64-apple-darwin": "synapses-x86_64-apple-darwin",
      "resources/synapses-x86_64-unknown-linux-gnu": "synapses-x86_64-unknown-linux-gnu"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "PLACEHOLDER_ED25519_PUBKEY",
      "endpoints": [
        "https://github.com/SynapsesOS/synapses-app/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
