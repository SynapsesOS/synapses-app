# This directory holds platform-specific synapses daemon binaries bundled into the app.
# Files are placed here by CI before `tauri build` runs:
#
#   synapses-aarch64-apple-darwin      (macOS Apple Silicon)
#   synapses-x86_64-apple-darwin       (macOS Intel)
#   synapses-x86_64-unknown-linux-gnu  (Linux x86_64)
#
# Do NOT commit actual binaries. CI downloads them from the synapses GitHub Release
# matching the version in tauri.conf.json before building.
